# ==========================================
# КОНФИГУРАЦИЯ БОТА "СПРАВОЧНАЯ КОЛОМНЫ"
# ==========================================

# --- Токен бота для жителей ---
# Получить: написать @BotFather в Telegram → /newbot
CITIZEN_BOT_TOKEN=your_citizen_bot_token_here

# --- Токен бота для сотрудников администрации ---
# Получить: написать @BotFather в Telegram → /newbot
# Этот бот должен быть добавлен в Telegram-группу сотрудников
ADMIN_BOT_TOKEN=your_admin_bot_token_here

# --- ID Telegram-группы сотрудников ---
# Как получить: добавьте @getidsbot в группу → он покажет chat_id (отрицательное число)
ADMIN_GROUP_CHAT_ID=-1001234567890

# --- API-ключ Groq (бесплатно, без карты) ---
# Зарегистрироваться: https://console.groq.com
# Бесплатный тариф: 6000 токенов/мин, 30 запросов/мин
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Модель (по умолчанию llama-3.3-70b-versatile) ---
GROQ_MODEL=llama-3.3-70b-versatile

# --- Webhook (только для продакшн-деплоя на Render.com) ---
# Формат: https://ВАШ_APP_NAME.onrender.com
# Оставьте пустым для локального запуска (polling-режим)
WEBHOOK_URL=
